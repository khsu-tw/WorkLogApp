{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Launcher (GUI)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/launcher.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run Flask Only (dev)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
